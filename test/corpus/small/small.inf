!% +/Users/joel/if/inform6lib/
!% $GRAMMAR_META_FLAG=1



Include "Parser";

!! This is the doc comment for TheRoom

Object TheRoom "The Room"
  has light
  private
    super_secret "Hello.",
  with
    description "The Room.",
    before [;
      Jump:
        MyFunc(10, 20);
    ],
;

Object -> "So quiet";

Class Room;
Room OtherRoom;
Object SimpleRoom;
!

Constant NOPE;

[Foo x;
  if (action == ##Jump) print "hello";
  switch (x) {
    TheRoom: "Hey";
  }
  Achieved(x);
];


Global c = 42;  !! Doc comment for c


!! This is a doc comment for MyFunc.
!! It goes over several lines.

#IfDef UNKNOWN;
Constant BAR_BAR;
#EndIf;

#IfDef IS_SET;
Constant IS_SET_CONST;
#EndIf;

#IfDef NOT_SET;
Constant NOT_SET_CONST;
#EndIf;

[ MyFunc a b if ;
    print a, b, "^";
    if = 42;
    #IfDef DEBUG;
    print "debug";
    #EndIf;
    Foo();
    ! if (true) { print "true"; }
];

[ An; print "ANNN"; ];

[ Initialise a b ;
    ! print (An) TheRoom, " ";
    ! print (A) TheRoom;
    ! print (address) TheRoom;
    ! print (object) TheRoom;
    a = description;
    print (property) a;
    location = TheRoom;
    print a, b, c, NOPE;
    ! if (true) { FoodFood() };
];


[ MyScopeFunc;
];

Include "VerbLib";
Include "Grammar";

[ FoozleSub; print "hey"; ];

Verb meta 'foozle'
  * noun scope=MyScopeFunc -> Foozle meta
  * creature light -> Foozle meta;

Constant Foozle 10;


Array x --> Foozle;

#IfDef DEBUG;  ! a known, active constant, should raise no warning
#EndIf;

#IfDef HAS_HINTS; ! an "understood" but not defined/active constant, should raise no warning
#EndIf;

#IfDef HASHINTS; ! not the right spelling, not "understood", should show a warning
#EndIf;