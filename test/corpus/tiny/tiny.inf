Include "lib";

Property room_func;
Property description;
Attribute my_attr;
Class Room
  with
    name 'my-name',
    room_func [; ],
 ;

Array arr --> 10 20 30;
Constant MY_CONST 42;
Global foo ;   !! A docstring for foo

Room TheRoom "The Room"
  has my_attr
  with
    description
      "The description TheRoom if Room room theroom If verb Verb. but also
      this",
    before [; ! Pragma:Prop
      self.Room::room_func();
      print self.description();
      Foozle: "You foozle!";
    ]
;

!! A docstring for MyFunc

[ MyFunc a b ;
  if (a) print b;
  if (a == ##Foozle) { }
  print (string) TheRoom.description();
  print (property) description;
  print LIB_CONST;
  Foozle(1, 2, 3);
];


[ Main;
  print foo, MY_CONST, arr-->0;
  #IfDef COND;
    print "outer ", TheRoom.description();
  #EndIf;
  #IfDef NOT_KNOWN;
    #IfDef COND;
      print TheRoom.description();
    #EndIf;
  #EndIF;
  MyFunc();
];

[ Foozle apple berry cherry;
  print apple, berry, cherry;
  ! This sub is not actually related to the Foozle action
];

!! Here the action info

[ FoozleSub;
];


Verb 'foozle'
  * noun -> Foozle
;