Property room_func;
Property description;
Attribute my_attr;

Class Room
  with
    name 'my-name',
    room_func [; ],
 ;

Array arr --> 10 20 30;
Constant MY_CONST 42;
Global foo 13;   !! A docstring for foo

Room TheRoom "The Room"
  has my_attr
  with
    description "The description TheRoom if Room room theroom If verb Verb.",
    before [;
      self.Room::room_func();
      print self.description();
      Foozle: "You foozle!";
    ]
;

!! A docstring for MyFunc

[ MyFunc a b ;
  if (a) print b;
  print (string) TheRoom.description();
  print (property) description;
];

[ Main;
  print foo, MY_CONST, arr-->0;
  MyFunc();
];

[ Foozle;
  ! This sub is not actually related to the Foozle action
];

[ FoozleSub;
];


Verb 'foozle'
  * noun -> Foozle;